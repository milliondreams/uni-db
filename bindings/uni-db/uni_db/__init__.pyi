    @property
    def is_unbounded(self) -> bool: ...
    @property
    def is_finite(self) -> bool: ...
    def contains_point(self, point_ms: int) -> bool: ...
    def overlaps(self, other: Btic) -> bool: ...
    def contains(self, other: Btic) -> bool: ...
    def before(self, other: Btic) -> bool: ...
