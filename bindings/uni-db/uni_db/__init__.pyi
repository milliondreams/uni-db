# =============================================================================
# Session (Sync)
# =============================================================================

class Session:
    """A query session with scoped variables.

    Sessions are the primary scope for reads and the factory for transactions.
    Create via ``db.session()``.

    Example::

        session = db.session()
        session.set("threshold", 0.5)
        results = session.query("MATCH (n) WHERE n.score > $threshold RETURN n")
    """

    # --- Parameters ---
    def params(self) -> Params: ...

    # --- Cypher Reads ---
    def query(
        self, cypher: str, params: dict[str, Any] | None = None
    ) -> QueryResult: ...
    def query_with(self, cypher: str) -> SessionQueryBuilder: ...

    # --- Locy ---
    def locy(
        self, program: str, params: dict[str, Any] | None = None
    ) -> LocyResult: ...
    def locy_with(self, program: str) -> SessionLocyBuilder: ...
    def rules(self) -> RuleRegistry: ...
    def compile_locy(self, program: str) -> CompiledProgram: ...

    # --- Prepared Statements ---
    def prepare(self, cypher: str) -> PreparedQuery: ...
    def prepare_locy(self, program: str) -> PreparedLocy: ...

    # --- Transaction Factory ---
    def tx(self) -> Transaction: ...
    def tx_with(self) -> TransactionBuilder: ...

    # --- Forks ---
    def fork(self, name: str) -> ForkBuilder: ...
    def fork_schema(self) -> ForkSchemaBuilder: ...
    def is_forked(self) -> bool: ...

    # --- Maintenance ---
    def flush(self) -> None: ...

    # --- Version Pinning ---
    def pin_to_version(self, snapshot_id: str) -> None: ...
    def pin_to_timestamp(self, epoch_secs: float) -> None: ...
    def refresh(self) -> None: ...
    def is_pinned(self) -> bool: ...

    # --- Hooks & Notifications ---
    def add_hook(self, hook: Any) -> None: ...
    def remove_hook(self, name: str) -> bool: ...
    def list_hooks(self) -> list[str]: ...
    def clear_hooks(self) -> None: ...
    def watch(self) -> CommitStream: ...
    def watch_with(self) -> WatchBuilder: ...

    # --- Cancellation ---
    def cancel(self) -> None: ...
    def cancellation_token(self) -> CancellationToken: ...

    # --- Observability ---
    def id(self) -> str: ...
    def capabilities(self) -> SessionCapabilities: ...
    def metrics(self) -> SessionMetrics: ...

    # --- Plugins ---
    def set_plugin_id(self, plugin_id: str) -> None: ...
    def set_plugin_version(self, version: str) -> None: ...
    def load_python_plugin(
        self, module_src: str, module_name: str, grants: list[str] | None = None
    ) -> dict[str, Any]: ...
    def finalize_plugin(
        self,
        plugin_id: str,
        version: str | None = None,
        grants: list[str] | None = None,
    ) -> dict[str, Any]: ...
    def scalar_fn(
        self,
        name: str,
        args: Any,
        returns: str,
        vectorized: bool = False,
        determinism: str = "pure",
    ) -> Callable[..., Any]: ...
    def aggregate_fn(
        self, name: str, args: Any, returns: str, determinism: str = "pure"
    ) -> Callable[..., Any]: ...
    def procedure(
        self, name: str, args: Any, yields: Any, mode: str = "read"
    ) -> Callable[..., Any]: ...

    # --- Context Manager ---
    def __enter__(self) -> Session: ...
    def __exit__(
        self,
        exc_type: type[BaseException] | None,
        exc_val: BaseException | None,
        exc_tb: Any,
    ) -> bool: ...

# =============================================================================
# Transaction (Sync)
# =============================================================================

class Transaction:
    """A database transaction with ACID guarantees.

    Use as a context manager for automatic rollback on error::

        with session.tx() as tx:
            tx.execute("CREATE (n:Person {name: 'Alice'})")
            tx.commit()
    """

    # --- Cypher Reads ---
    def query(
        self, cypher: str, params: dict[str, Any] | None = None
    ) -> QueryResult: ...
    def query_with(self, cypher: str) -> TxQueryBuilder: ...

    # --- Cypher Writes ---
    def execute(
        self, cypher: str, params: dict[str, Any] | None = None
    ) -> ExecuteResult: ...
    def execute_with(self, cypher: str) -> TxExecuteBuilder: ...

    # --- Locy ---
    def locy(
        self, program: str, params: dict[str, Any] | None = None
    ) -> LocyResult: ...
    def locy_with(self, program: str) -> TxLocyBuilder: ...

    # --- Apply DerivedFactSet ---
    def apply(self, derived: DerivedFactSet) -> ApplyResult: ...
    def apply_with(self, derived: DerivedFactSet) -> ApplyBuilder: ...

    # --- Rule Management ---
    def rules(self) -> RuleRegistry: ...

    # --- Prepared Statements ---
    def prepare(self, cypher: str) -> PreparedQuery: ...
    def prepare_locy(self, program: str) -> PreparedLocy: ...

    # --- Lifecycle ---
    def commit(self) -> CommitResult: ...
    def rollback(self) -> None: ...
    def id(self) -> str: ...
    def started_at_version(self) -> int: ...
    def is_dirty(self) -> bool: ...
    def is_completed(self) -> bool: ...

    # --- Cancellation ---
    def cancel(self) -> None: ...
    def cancellation_token(self) -> CancellationToken: ...

    # --- Bulk Loading ---
    def bulk_writer(self) -> TxBulkWriterBuilder: ...
    def appender(self, label: str) -> StreamingAppender: ...
    def appender_builder(self, label: str) -> TxAppenderBuilder: ...

    # --- Context Manager ---
    def __enter__(self) -> Transaction: ...
    def __exit__(
        self,
        exc_type: type[BaseException] | None,
        exc_val: BaseException | None,
        exc_tb: Any,
    ) -> bool: ...

class TxBulkWriterBuilder:
