    async def watch(self) -> AsyncCommitStream: ...
    async def watch_with(self) -> WatchBuilder: ...

    # --- Cancellation ---
    async def cancel(self) -> None: ...
    async def cancellation_token(self) -> CancellationToken: ...

    # --- Observability ---
    async def id(self) -> str: ...
