    Query results return native Python types by default. Use ``Value`` when
    you need to distinguish types explicitly.
    """

    @staticmethod
    def null() -> Value: ...
    @staticmethod
    def bool(v: bool) -> Value: ...
    @staticmethod
    def int(v: int) -> Value: ...
    @staticmethod
    def float(v: float) -> Value: ...
    @staticmethod
    def string(v: str) -> Value: ...
    @staticmethod
    def bytes(v: bytes) -> Value: ...
    @staticmethod
    def vector(v: builtins.list[builtins.float]) -> Value: ...
    @staticmethod
    def btic(literal: str) -> Value: ...
    @property
    def type_name(self) -> str: ...
    def is_null(self) -> builtins.bool: ...
    def is_bool(self) -> builtins.bool: ...
    def is_int(self) -> builtins.bool: ...
    def is_float(self) -> builtins.bool: ...
    def is_string(self) -> builtins.bool: ...
    def is_btic(self) -> builtins.bool: ...
    def to_python(self) -> Any: ...
    def __repr__(self) -> str: ...
    def __bool__(self) -> builtins.bool: ...

