class UniLocyIncompleteError(UniError):
    """Locy evaluation stopped early (timeout or iteration/depth limit).

    Carries diagnostic attributes set when raised: ``reason``, ``elapsed_ms``,
    ``limit_ms``, ``max_iterations``, ``completed_strata``, ``total_strata``,
    ``incomplete_rules``, ``skipped_rules``, ``complement_rules_affected``.
    """

    reason: str
    elapsed_ms: int
    limit_ms: int
    max_iterations: int
    completed_strata: int
    total_strata: int
    incomplete_rules: list[str]
    skipped_rules: list[str]
    complement_rules_affected: list[str]

