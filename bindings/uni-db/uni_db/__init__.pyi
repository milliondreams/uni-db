    """

    @property
    def nodes(self) -> list[Node]: ...
    @property
    def edges(self) -> list[Edge]: ...
    @property
    def start(self) -> Node | None: ...
    @property
    def end(self) -> Node | None: ...
    def is_empty(self) -> bool: ...
    def __len__(self) -> int: ...
    def __getitem__(self, idx: int) -> Node | Edge: ...
    def __iter__(self) -> Iterator[Node | Edge]: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
    def __bool__(self) -> bool: ...
    def __repr__(self) -> str: ...

class QueryResult:
    """Rich query result with rows, metrics, warnings, and column names.

    Implements the sequence protocol: ``for row in result``, ``result[0]``,
    ``len(result)`` all work.
    """

    metrics: QueryMetrics
    warnings: list[QueryWarning]
    columns: list[str]

    @property
    def rows(self) -> list[Row]: ...
    def __len__(self) -> int: ...
    def __getitem__(self, idx: int) -> Row: ...
    def __iter__(self) -> Iterator[Row]: ...
    def __bool__(self) -> bool: ...

