class Uni:
    """
    The main synchronous Uni database interface.

    Uni is lifecycle and admin. It opens, shuts down, manages schema,
    and stamps out Sessions. It does not execute queries or mutations.

    Example::

        db = Uni.temporary()
        db.schema().label("Person").property("name", "String").apply()
        session = db.session()
        session.execute("CREATE (n:Person {name: 'Alice'})")
        results = session.query("MATCH (n:Person) RETURN n.name AS name")
    """

    # Static Factories
    @staticmethod
    def open(path: str) -> Uni: ...
    @staticmethod
    def temporary() -> Uni: ...
    @staticmethod
    def in_memory() -> Uni: ...
    @staticmethod
    def create(path: str) -> Uni: ...
    @staticmethod
    def open_existing(path: str) -> Uni: ...
    @staticmethod
    def builder() -> UniBuilder: ...

    # Session Factory
    def session(self) -> Session: ...
    def session_template(self) -> SessionTemplateBuilder: ...

    # Schema DDL & Inspection
    def schema(self) -> SchemaBuilder: ...
    def label_exists(self, name: str) -> bool: ...
    def edge_type_exists(self, name: str) -> bool: ...
    def list_labels(self) -> list[str]: ...
    def list_edge_types(self) -> list[str]: ...
    def get_label_info(self, name: str) -> LabelInfo | None: ...
    def get_schema(self) -> dict[str, Any]: ...
    def get_schema_typed(self) -> Schema: ...
    def load_schema(self, path: str) -> None: ...
    def save_schema(self, path: str) -> None: ...

    # Global Locy Rules
    def register_rules(self, program: str) -> None: ...
    def clear_rules(self) -> None: ...

    # Xervo
    def xervo(self) -> Xervo: ...

    # Storage Admin
    def flush(self) -> None: ...
    def compact_label(self, label: str) -> CompactionStats: ...
    def compact_edge_type(self, edge_type: str) -> CompactionStats: ...
    def wait_for_compaction(self) -> None: ...

    # Snapshots
    def create_snapshot(self, name: str | None = None) -> str: ...
