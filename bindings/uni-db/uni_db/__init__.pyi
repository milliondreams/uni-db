# =============================================================================
# Uni (Sync)
# =============================================================================

class Uni:
    """
    The main synchronous Uni database interface.

    Uni is lifecycle and admin. It opens, shuts down, manages schema,
    and stamps out Sessions. It does not execute queries or mutations.

    Example::

        db = Uni.temporary()
        db.schema().label("Person").property("name", "String").apply()
        session = db.session()
        session.execute("CREATE (n:Person {name: 'Alice'})")
        results = session.query("MATCH (n:Person) RETURN n.name AS name")
    """

    # Static Factories
    @staticmethod
    def open(path: str) -> Uni: ...
    @staticmethod
    def temporary() -> Uni: ...
    @staticmethod
    def in_memory() -> Uni: ...
    @staticmethod
    def create(path: str) -> Uni: ...
    @staticmethod
    def open_existing(path: str) -> Uni: ...
    @staticmethod
    def builder() -> UniBuilder: ...

    # Session Factory
    def session(self) -> Session: ...
    def session_template(self) -> SessionTemplateBuilder: ...

    # Schema DDL & Inspection
    def schema(self) -> SchemaBuilder: ...
    def label_exists(self, name: str) -> bool: ...
    def edge_type_exists(self, name: str) -> bool: ...
    def list_labels(self) -> list[str]: ...
    def list_edge_types(self) -> list[str]: ...
    def get_label_info(self, name: str) -> LabelInfo | None: ...
    def get_edge_type_info(self, name: str) -> EdgeTypeInfo | None: ...
    def load_schema(self, path: str) -> None: ...
    def save_schema(self, path: str) -> None: ...

    # Facades
    def rules(self) -> RuleRegistry: ...
    def xervo(self) -> Xervo: ...
    def compaction(self) -> Compaction: ...
    def indexes(self) -> Indexes: ...

    # Storage Admin
    def flush(self) -> None: ...

    # Snapshots
    def create_snapshot(self, name: str) -> str: ...
    def list_snapshots(self) -> list[SnapshotInfo]: ...
    def restore_snapshot(self, snapshot_id: str) -> None: ...

    # Fork Management & Diff/Promote
    def list_forks(self) -> list[ForkInfo]: ...
    def fork_info(self, name: str) -> ForkInfo | None: ...
    def drop_fork(self, name: str) -> None: ...
    def drop_fork_cascade(self, name: str) -> None: ...
    def tag_fork(self, fork_name: str, tag: str) -> None: ...
    def untag_fork(self, fork_name: str, tag: str) -> None: ...
    def list_fork_tags(self, fork_name: str) -> list[str]: ...
    def diff_fork_primary(self, fork_name: str) -> ForkDiff: ...
    def diff_forks(self, a: str, b: str) -> ForkDiff: ...
    def promote_from_fork(
        self, fork_name: str, patterns: list[PromotePattern]
    ) -> PromoteReport: ...
    def promote_from_fork_with_options(
        self,
        fork_name: str,
        patterns: list[PromotePattern],
        options: PromoteOptions,
    ) -> PromoteReport: ...

    # Observability & Lifecycle
    def metrics(self) -> DatabaseMetrics: ...
    def config(self) -> dict[str, Any]: ...
    def write_lease(self) -> WriteLease | None: ...
    def shutdown(self) -> None: ...

    # Plugins
    def load_rhai_plugin(
        self, script: str, grants: list[str] | None = None
    ) -> dict[str, Any]: ...
    def load_wasm_component(
        self, wasm_bytes: bytes, grants: list[str] | None = None
    ) -> dict[str, Any]: ...
    def load_wasm_extism(
        self, wasm_bytes: bytes, grants: list[str] | None = None
    ) -> dict[str, Any]: ...

    # Context Manager
    def __enter__(self) -> Uni: ...
    def __exit__(
        self,
        exc_type: type[BaseException] | None,
        exc_val: BaseException | None,
        exc_tb: Any,
    ) -> bool: ...

